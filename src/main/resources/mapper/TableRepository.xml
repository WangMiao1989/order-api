<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wm.mapper.TableRepository">
    <insert id="updateTableInfo" useGeneratedKeys="true" keyProperty="tableId" parameterType="com.wm.entity.TableEntity">
       Insert into public.t_table_info (
       	table_no 
       	,customer_cnt
       	,start_time
       	,create_user
       	,update_user
       ) values ( 
       	#{tableNo}
       	,#{customerCnt}
       	,#{startTime}
       	,#{createUser}
       	,#{updateUser}
       );
    </insert>
    
    <select id="selectTableInfo" resultType="com.wm.entity.TableEntity">
       SELECT
            table_id
            ,table_no
            ,customer_cnt
            ,start_time
            ,end_time
            ,create_user
            ,create_time
       		,update_user
       		,update_time
        FROM
            public.t_table_info
        where
        	table_no = #{tableNo}
        	and end_time is null
        order by update_time desc
        limit 1
    </select>
</mapper>