<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wm.mapper.CategoryRepository">
    <select id="findAllCategorys" resultType="com.wm.entity.CategoryEntity">
        SELECT
            id as category_id
            ,type
            , name
            , description
            , icon
        FROM
            #schema#.m_category
        ORDER BY
            id
    </select>
</mapper>