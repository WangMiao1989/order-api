<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wm.mapper.PrinterRepository">
    <select id="selectPrinterSn" resultType="String">
    	select
    		printer_sn
    	from
    		public.m_printer
    	where
    		tenant_id = #{tenantId}
    </select>
</mapper>